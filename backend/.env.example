# ==================== DATABASE ====================
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/nexusflow
# Railway: postgresql://user:pass@host:5432/dbname?sslmode=require
DATABASE_URL=postgresql://postgres:2121@localhost:5432/nexusflow

# ==================== JWT ====================
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=DW-yj9ALLM-CTzZiSBEOV_hMHYc-zBl23fBe11vnNwM
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== CORS ====================
# Frontend URL for CORS allowlist
FRONTEND_URL=http://localhost:5173

# ==================== APPLICATION ====================
APP_NAME=NexusFlow AI
DEBUG=True

# ==================== CLOUDINARY (Image Storage) ====================
# Get from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==================== QINIU (Alternative Image Storage) ====================
# Get from https://portal.qiniu.com
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_DOMAIN=

# ==================== AWS S3 (Future) ====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
