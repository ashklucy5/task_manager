SUPABASE_ANON_KEY=
SUPABASE_BUCKET=

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ==================== STORAGE STRATEGY ====================
# Options: cloudinary, qiniu, aws, supabase, local
IMAGE_STORAGE_STRATEGY=cloudinary